# SentinelVision PPE Safety Backend Configuration
# Copy this file to .env and modify as needed

# =============================================================================
# Application Settings
# =============================================================================
DEBUG=True
APP_NAME=SentinelVision PPE Safety

# =============================================================================
# Database
# =============================================================================
# SQLite for development
DATABASE_URL=sqlite+aiosqlite:///./sentinelvision.db

# PostgreSQL for production (uncomment and configure)
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sentinelvision

# =============================================================================
# ML Model Settings
# =============================================================================
# Detection confidence threshold (0.0 - 1.0)
DETECTION_CONFIDENCE_THRESHOLD=0.5
VIOLATION_CONFIDENCE_THRESHOLD=0.3
PERSON_MODEL_NAME=yolo11m.pt
PPE_CLASS_PROFILE=construction

# Construction profile defaults.
# For the upstream lab model, set PPE_CLASS_PROFILE=lab and update these lists to:
# PPE_PROMPTS=["safety goggles","face mask","lab coat","gloves","head mask"]
# REQUIRED_PPE=["safety goggles","face mask","lab coat"]
PPE_PROMPTS=["helmet","vest","gloves","boots","safety goggles"]
REQUIRED_PPE=["helmet","vest","safety goggles"]
VIOLATION_CLASSES=["no_helmet","no_goggle","no_gloves","no_boots"]
ACTION_VIOLATION_CLASSES=[]

# Face recognition similarity threshold (0.0 - 1.0)
FACE_RECOGNITION_THRESHOLD=0.6

# Real runtime should fail instead of silently producing fake detections.
USE_MOCK_DETECTOR=false
USE_MOCK_FACE=false
FAIL_ON_MISSING_MODELS=true
ALLOW_BOX_MASK_FALLBACK=false

# =============================================================================
# Video Processing
# =============================================================================
# Target frames per second for processing
FRAME_SAMPLE_RATE=10
LIVE_STREAM_DISPLAY_FPS=30
LIVE_STREAM_PROCESS_FPS=4
LIVE_STREAM_QUEUE_SIZE=1
MULTI_SCALE_ENABLED=true
MULTI_SCALE_FACTORS=[1.0,1.5]
USE_SAM3=false
USE_SAM2=true

# Number of consecutive frames required for stable detection
TEMPORAL_BUFFER_SIZE=3

# Maximum frames to keep an unmatched track alive
MAX_TRACK_AGE=30

# Minimum detections before a track is confirmed
MIN_TRACK_HITS=3

# =============================================================================
# CORS (Cross-Origin Resource Sharing)
# =============================================================================
# Allowed origins for frontend (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
